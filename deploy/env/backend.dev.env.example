APP_NAME=AutoTestManager Backend
APP_ENV=development
LOG_LEVEL=INFO

# Change these values for your environment.
JWT_SECRET_KEY=CHANGE-THIS-TO-RANDOM-SECRET
JWT_EXPIRE_MINUTES=1440

DB_PATH=/data/autotestmanager.db
RESULT_BASE_PATH=/data/results

SVN_UPLOAD_HOST_IP=
SVN_UPLOAD_HOST_USER=
SVN_UPLOAD_HOST_PASSWORD=
SVN_UPLOAD_DIR=/data/svn_repo
SVN_UPLOAD_COMMAND=svn_bin_checkin

DEFAULT_ADMIN_USER_ID=admin
DEFAULT_ADMIN_PASSWORD=admin1234
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_MODULE_NAME=SYSTEM

# deploy/run-dev.sh
BACKEND_PORT=10223
FRONTEND_PORT=4203
BACKEND_DEBUG_PORT=5678
SQLITE_WEB_ENABLED=1
SQLITE_WEB_PORT=8080
SQLITE_WEB_READ_ONLY=0
VITE_API_BASE_URL=
