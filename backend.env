APP_NAME=AutoTestManager Backend
APP_ENV=offline
LOG_LEVEL=INFO

# 반드시 임의의 긴 문자열로 변경 (운영 보안 필수)
JWT_SECRET_KEY=asdfasdfasdf
JWT_EXPIRE_MINUTES=1440

DB_PATH=/data/autotestmanager.db
RESULT_BASE_PATH=/data/results
SQLITE_WEB_PORT=8080
SQLITE_WEB_READ_ONLY=0

SVN_UPLOAD_HOST_IP=-
SVN_UPLOAD_HOST_USER=hyun
SVN_UPLOAD_HOST_PASSWORD=931014
SVN_UPLOAD_DIR=/home/hyun/develope/AutoTestManager/backend/data/svn_repo
SVN_UPLOAD_COMMAND=/home/hyun/.local/bin/svn_bin_checkin

# 최초 컨테이너 실행 시 DB에 seed로 생성됨
# 이후 변경하려면 웹 UI의 My Page에서 비밀번호 변경 사용
DEFAULT_ADMIN_USER_ID=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_MODULE_NAME=SYSTEM
