APP_NAME=AutoTestManager Backend
APP_ENV=local
LOG_LEVEL=INFO

JWT_SECRET_KEY=change-this-secret
JWT_EXPIRE_MINUTES=1440

# WSL/local development example
# Docker container runtime can override these paths separately.
DB_PATH=/home/hyun/develope/AutoTestManager/backend/data/autotestmanager.db
RESULT_BASE_PATH=/home/hyun/develope/AutoTestManager/backend/data/results
BACKEND_PORT=10223

# Local DB browser started by run-dev.sh
SQLITE_WEB_ENABLED=1
SQLITE_WEB_HOST=0.0.0.0
SQLITE_WEB_PORT=8080
SQLITE_WEB_READ_ONLY=0

SVN_UPLOAD_HOST_IP=
SVN_UPLOAD_HOST_USER=
SVN_UPLOAD_HOST_PASSWORD=
SVN_UPLOAD_DIR=/home/hyun/develope/AutoTestManager/backend/data/svn_repo
SVN_UPLOAD_COMMAND=svn_bin_checkin

DEFAULT_ADMIN_USER_ID=admin
DEFAULT_ADMIN_PASSWORD=admin1234
DEFAULT_ADMIN_NAME=Default Admin
DEFAULT_ADMIN_MODULE_NAME=SYSTEM
